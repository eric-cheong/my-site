# ─── Server ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Admin auth — set ONE of these. Hash is strongly preferred.
# Generate with: npm run hash:password
ADMIN_PASSWORD_HASH=
# Dev-only fallback (plaintext). Leave blank in production.
ADMIN_PASSWORD=

# CORS — comma-separated list of allowed origins in production
ALLOWED_ORIGINS=https://wootong.com,https://www.wootong.com

# ─── Client (exposed to browser — must be prefixed VITE_) ────────
VITE_API_URL=http://localhost:3001/api
# Optional: set a public site URL for canonical / OG tags
VITE_SITE_URL=https://wootong.com
# Optional: enable Vercel Speed Insights / Analytics in production
VITE_ENABLE_ANALYTICS=false
